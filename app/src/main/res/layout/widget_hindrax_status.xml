<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_status_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_hindrax_panel"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:text="HINDRAX_NODE"
            android:textColor="#00FF66"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_status_refresh"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="R"
            android:textColor="#00FFFF"
            android:textSize="20sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_status_api"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="API: --"
        android:textColor="#00FFFF"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_status_tasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="monospace"
        android:text="TAREAS 0/0"
        android:textColor="#FFFFFF"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widget_status_inventory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="ITEMS 0"
        android:textColor="#FFFFFF"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widget_status_sync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace"
        android:text="SYNC --:--"
        android:textColor="#888888"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/widget_status_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="#FF5252"
        android:textSize="10sp" />
</LinearLayout>
